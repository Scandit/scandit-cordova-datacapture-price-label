<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0" id="scandit-cordova-datacapture-price-label" version="8.3.1">
    <name>ScanditPriceLabel</name>
    <engines>
        <engine name="cordova-ios" version=">=5.0.0" />
        <engine name="cordova-android" version=">=10.0.0" />
    </engines>
    <platform name="ios">
        <config-file parent="/*" target="config.xml">
            <feature name="ScanditPriceLabel">
                <param name="ios-package" value="ScanditPriceLabelPlugin" />
                <param name="onload" value="true" />
            </feature>
        </config-file>
        <header-file src="src/ios/ScanditPriceLabelPlugin-Bridging-Header.h" type="BridgingHeader" />
        <source-file src="src/ios/ScanditPriceLabelPlugin.swift" />
        <podspec>
            <pods use-frameworks="true">
                <pod name="ScanditPriceLabel" spec="= 8.3.1" />
            </pods>
        </podspec>
    </platform>
    <platform name="android">
        <config-file parent="/*" target="config.xml">
            <feature name="ScanditPriceLabel">
                <param name="android-package" value="com.scandit.datacapture.cordova.pricelabel.ScanditPriceLabel" />
            </feature>
        </config-file>
        <source-file src="src/android/ScanditPriceLabel.kt" target-dir="kotlin/com/scandit/datacapture/cordova/pricelabel" />
        <framework custom="true" src="src/android/build.gradle" type="gradleReference" />
        <hook src="src/hooks/support-kotlin.js" type="after_plugin_install" />
    </platform>
</plugin>